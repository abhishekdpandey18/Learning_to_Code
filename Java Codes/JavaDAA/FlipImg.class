class FlipImg {
    public int[][] flipAndInvertImage(int[][] image) {
        int n = image.length;

        for(int i = 0 ; i<n; i++){
            int lo = 0;
            int hi = image[i].length-1;

            while(lo <= hi ){
                int temp  = image[i][lo]^1;
                image[i][lo] = image[i][hi]^1;
                image[i][hi] = temp;
                lo++;
                hi--;

            }
        }
        return image;
        
    }
}
